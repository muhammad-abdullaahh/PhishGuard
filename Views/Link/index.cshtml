@model List<PhishGuard.Models.Link>
@{
    ViewData["Title"] = "PhishGuard Dashboard";
    var total = Model?.Count() ?? 0;
    var safe = Model?.Count(l => l.Status == "Safe") ?? 0;
    var phishing = Model?.Count(l => l.Status == "Phishing") ?? 0;
    var unknown = Model?.Count(l => l.Status == "Unknown") ?? 0;
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />

<style>
  body { background: #0b0f14; color: #cfe8ff; font-family: Inter, system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', Arial; }
  .card-dark { background: linear-gradient(180deg,#0f1720 0%, #07101a 100%); border: 1px solid rgba(60,200,255,0.07); box-shadow: 0 6px 18px rgba(0,0,0,0.6); }
  .neon-accent { color: #00e5ff; }
  .accent-bg { background: linear-gradient(90deg, rgba(0,229,255,0.08), rgba(0,150,255,0.02)); border-left: 4px solid #00e5ff; }
  .stat-card { transition: transform .15s ease, box-shadow .15s ease; }
  .stat-card:hover { transform: translateY(-6px); box-shadow: 0 14px 30px rgba(0,229,255,0.05); }
  .btn-secure { background: #0b1220; color: #bfefff; border: 1px solid rgba(0,229,255,0.12); }
  .btn-secure:hover { background: #071425; color: #e6ffff; box-shadow: 0 6px 18px rgba(0,229,255,0.06); }
  .badge-safe { background: #198754; color:#fff; }
  .badge-phish { background: #dc3545; color:#fff; }
  .badge-unknown { background: #ffc107; color:#0b0f14; }
  .url-input { background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.04); color: #e6f7ff; }
  .card-title { color: #9fdcff; }
  .table-dark-custom { background: transparent; color: #dff6ff; }
  .small-muted { color: #7eaebf; font-size: .85rem; }
  .shadow-neon { box-shadow: 0 6px 26px rgba(0,229,255,0.04); }
  a.text-neon:hover { color: #7ffcff; text-decoration: underline; }
</style>

<div class="container-fluid py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="h3 neon-accent"><i class="fa-solid fa-shield-halved me-2"></i>PhishGuard SOC</h1>
      <div class="small-muted">Real-time phishing link scanning &amp; analytics</div>
    </div>
    <div>
      <span class="badge badge-secondary px-3 py-2 card-dark">Scanned: <strong class="ms-2">@total</strong></span>
    </div>
  </div>

  @if (TempData["Success"] != null)
  {
      <div class="alert alert-success alert-dismissible fade show card-dark border-success text-success mb-4" role="alert">
          <i class="fa-solid fa-circle-check me-2"></i> @TempData["Success"]
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
  }
  @if (TempData["Error"] != null)
  {
      <div class="alert alert-danger alert-dismissible fade show card-dark border-danger text-danger mb-4" role="alert">
          <i class="fa-solid fa-triangle-exclamation me-2"></i> @TempData["Error"]
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
  }

  <div class="row mb-4">
    <div class="col-12">
      <div class="card card-dark p-3 shadow-neon">
        <form asp-controller="Link" asp-action="CheckLink" method="post" class="row g-2">
          @Html.AntiForgeryToken()
          <div class="col-lg-9 col-md-8">
            <label class="form-label small-muted">Paste a URL to analyze</label>
            <input name="url" type="url" class="form-control form-control-lg url-input" placeholder="https://example.com/suspicious-link" required />
          </div>
          <div class="col-lg-3 col-md-4 d-flex align-items-end justify-content-end">
            <button type="submit" class="btn btn-secure btn-lg w-100">
              <i class="fa-solid fa-shield-halved me-2"></i>
              <span>Check Link</span>
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <div class="row g-3 mb-4">
    <div class="col-xl-3 col-md-6">
      <div class="card card-dark p-3 stat-card accent-bg">
        <div class="d-flex align-items-center">
          <div class="me-3 display-6 text-white"><i class="fa-solid fa-list-check neon-accent"></i></div>
          <div>
            <div class="card-title small-muted">Total Scanned</div>
            <div class="h4">@total</div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-xl-3 col-md-6">
      <div class="card card-dark p-3 stat-card">
        <div class="d-flex align-items-center">
          <div class="me-3 display-6 text-danger"><i class="fa-solid fa-bug"></i></div>
          <div>
            <div class="card-title small-muted">Phishing</div>
            <div class="h4 text-danger">@phishing</div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-xl-3 col-md-6">
      <div class="card card-dark p-3 stat-card">
        <div class="d-flex align-items-center">
          <div class="me-3 display-6 text-success"><i class="fa-solid fa-check-circle"></i></div>
          <div>
            <div class="card-title small-muted">Safe</div>
            <div class="h4 text-success">@safe</div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-xl-3 col-md-6">
      <div class="card card-dark p-3 stat-card">
        <div class="d-flex align-items-center">
          <div class="me-3 display-6 text-warning"><i class="fa-solid fa-question-circle"></i></div>
          <div>
            <div class="card-title small-muted">Unknown</div>
            <div class="h4 text-warning">@unknown</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="row g-3">
    <div class="col-xl-4">
      <div class="card card-dark p-3">
        <h5 class="mb-3 card-title"><i class="fa-solid fa-chart-pie me-2"></i>Status Distribution</h5>
        <canvas id="statusChart" width="400" height="320"></canvas>
        <div class="mt-3 small-muted">Distribution of results (Safe vs Phishing vs Unknown)</div>
      </div>
    </div>

    <div class="col-xl-8">
      <div class="card card-dark p-3">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <h5 class="mb-0 card-title"><i class="fa-solid fa-clock-rotate-left me-2"></i>Recent Scans</h5>
          <div class="small-muted">Latest 20</div>
        </div>

        <div class="table-responsive">
          <table class="table table-borderless table-dark-custom align-middle">
            <thead>
              <tr class="small-muted">
                <th>URL</th>
                <th>Status</th>
                <th>Date Checked</th>
                <th>Source</th>
              </tr>
            </thead>
            <tbody>
              @if (Model != null && Model.Any())
              {
                  foreach (var item in Model.OrderByDescending(l => l.CheckedDate).Take(20))
                  {
                      <tr>
                        <td style="max-width:420px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                          <a href="@item.URL" target="_blank" class="text-decoration-none text-neon" title="@item.URL">@item.URL</a>
                        </td>
                        <td>
                          @if (item.Status == "Safe")
                          {
                              <span class="badge badge-safe">Safe</span>
                          }
                          else if (item.Status == "Phishing")
                          {
                              <span class="badge badge-phish">Phishing</span>
                          }
                          else
                          {
                              <span class="badge badge-unknown">Unknown</span>
                          }
                        </td>
                        <td><span class="small-muted">@item.CheckedDate.ToString("g")</span></td>
                        <td><span class="small-muted">@item.Source</span></td>
                      </tr>
                  }
              }
              else
              {
                  <tr>
                    <td colspan="4" class="text-center small-muted">No scans yet. Paste a URL above to begin.</td>
                  </tr>
              }
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<script>
  // Counts from server-side
  const statusCounts = [@safe, @phishing, @unknown];

  const ctx = document.getElementById('statusChart').getContext('2d');
  const statusChart = new Chart(ctx, {
    type: 'pie',
    data: {
      labels: ['Safe', 'Phishing', 'Unknown'],
      datasets: [{
        data: statusCounts,
        backgroundColor: ['#00c851', '#ff3547', '#ffd166'],
        hoverOffset: 8,
        borderColor: '#0b0f14',
        borderWidth: 2
      }]
    },
    options: {
      responsive: true,
      plugins: {
        legend: { labels: { color: '#bfefff' } },
        tooltip: {
          backgroundColor: '#0b1220',
          titleColor: '#e6ffff',
          bodyColor: '#cfe8ff'
        }
      }
    }
  });
</script>