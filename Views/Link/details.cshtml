@model PhishGuard.Models.Link
@{
    ViewData["Title"] = "Details";
}

<h2>Link Details</h2>
<div>
    <dl class="row">
        <dt class="col-sm-2">URL</dt>
        <dd class="col-sm-10">@Model.URL</dd>

        <dt class="col-sm-2">Status</dt>
        <dd class="col-sm-10">@Model.Status</dd>

        <dt class="col-sm-2">Checked Date</dt>
        <dd class="col-sm-10">@Model.CheckedDate</dd>

        <dt class="col-sm-2">Source</dt>
        <dd class="col-sm-10">@Model.Source</dd>
    </dl>
</div>
